{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DeX Trading Agent",
  "version": "1.0.0",
  "identifier": "com.dex-trading-agent.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DeX Trading Agent",
        "width": 1600,
        "height": 1000,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "minWidth": 1200,
        "minHeight": 800,
        "maximized": false,
        "visible": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "contentProtected": false,
        "skipTaskbar": false,
        "titleBarStyle": "Visible",
        "hiddenTitle": false,
        "acceptFirstMouse": false,
        "tabbingIdentifier": null,
        "additionalBrowserArgs": "",
        "userAgent": "DeX Trading Agent Desktop App",
        "proxyUrl": null,
        "x": null,
        "y": null
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "script-src": "'self' 'unsafe-eval' https://s3.tradingview.com https://www.tradingview.com",
        "img-src": "'self' data: https: blob:",
        "connect-src": "'self' http://localhost:8000 https://api.hyperliquid.xyz https://api.testnet.hyperliquid.xyz https://openrouter.ai https://api.coingecko.com https://s3.tradingview.com https://www.tradingview.com wss://*.tradingview.com",
        "font-src": "'self' https://s3.tradingview.com https://www.tradingview.com",
        "frame-src": "'self' https: https://www.tradingview.com",
        "object-src": "'none'",
        "media-src": "'self' blob: https://s3.tradingview.com"
      "capabilities": [
        "default"
      ],
      "dangerousDisableAssetCspModification": false,
      "freezePrototype": true,
      "useRegexProcessGlobbing": false,
      "usePatternProcessGlobbing": true,
      "dangerousUseHttpScheme": false,
      "dangerousRemoteDomainIpcAccess": []
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "2026 DeX Trading Agent",
    "category": "DeveloperTool",
    "shortDescription": "AI-powered perpetual futures trading",
    "longDescription": "DeX Trading Agent is an AI-powered perpetual futures trading platform integrated with Hyperliquid exchange",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13",
      "license": "MIT",
      "signingIdentity": null,
      "entitlements": null,
      "exceptionDomain": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": null,
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "allowDowngrades": false
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  },
  "plugins": {
    "store": {
      "freeze": false
    }
  }
}
